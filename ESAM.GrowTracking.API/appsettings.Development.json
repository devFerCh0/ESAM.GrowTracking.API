        //"KeysPath": "C:\\ProgramData\\GrowTracking\\DataProtection\\Keys"
        //"KeysPath": "C:/DataProtectionKeys/GrowTracking"
    },
    "ForwardedHeadersSettings": {
        "KnownNetworks": [],
        "KnownProxies": []
    },
    "JwtSettings": {
        "Issuer": "https://localhost:7001",
        //"Issuer": "https://localhost:7000",
        "Audience": "https://localhost:7001",
        //"Audience": "https://localhost:7000",
        "SecretKey": "GrowTracking@ESAM-JWT-Dev-SecretKey-2024!#$%^&*()"
        //"SecretKey": "GrT-Dev-2024!K8mX5nQ7rP2sL9wZ0vBcYeUhIjFaDtNg"
        //"SecretKey": "GrowTracking@Dev#2024!SecureKey$RandomChars&XYZ"
        //"SecretKey": "ESAM-GrowTracking-Local-Dev-JWT-K3y-2024!X9pQ#mZ@nRvW-abcdefgh"
    },
    "AuthSecuritySettings": {
        "MaxFailedAttempts": 5,
        "LockoutDuration": "00:15:00",
        "FailedAttemptsResetDuration": "01:00:00"
    },
    "CleanupSettings": {
        "InitialDelay": "00:01:00",
        "Interval": "01:00:00",
        "BatchSize": 500
    },
    "TokenLifetimeSettings": {
        "TemporaryAccessTokenLifetimeMinutes": 5,
        "SessionAccessTokenLifetimeMinutes": 15,
        "RefreshTokenLifetimeDays": 7,
        "SessionAbsoluteLifetimeDays": 30,
        "SessionIdleWindowDays": 7
    },
    "CookieSettings": {
        "CookieName": "rt",
        "UseHostPrefix": false,
        "AllowRefreshTokenHeader": true,
        "AlwaysSecure": false,
        "XsrfCookieName": "XSRF-TOKEN",
        "XsrfCookieExpiresMinutes": 60,
        //"XsrfCookieExpiresMinutes": 30,
        "Domain": null,
        "SameSite": "Lax",
        "Path": "/",
        "XsrfExemptPaths": [
            "/api/auth/login",
            "/api/auth/refresh"
        ]
    },
    "CorsSettings": {
        "PolicyName": "CorsPolicy",
        "AllowedOrigins": [
            "http://localhost:3000",
            "https://localhost:3000",
            "http://localhost:4200",
            "https://localhost:4200",
            "https://localhost:5000",
            "http://localhost:5000",
            "https://localhost:5001",
            "http://localhost:5001",
            "https://localhost:5173",
            "http://localhost:5173",
            "http://localhost:7000",
            "https://localhost:7000",
            "http://localhost:7001",
            "https://localhost:7001",
            "http://localhost:8080",
            "https://localhost:8080"
        ],
        "AllowedOriginWildcards": [],
        "AllowedOriginRegex": [],
        "AllowedHeaders": [
            "Content-Type",
            "Authorization",
            "X-Requested-With",
            "X-XSRF-TOKEN",
            "X-Refresh-Token"
        ],
        "AllowedMethods": [
            "GET",
            "HEAD",
            "POST",
            "PUT",
            "DELETE",
            "PATCH",
            "OPTIONS"
        ],
        "ExposeHeaders": [
            "X-XSRF-TOKEN"
        ],
        "AllowCredentials": true,
        "PreflightMaxAgeSeconds": 600,
        "AllowHttpOnLocalhost": true,
        "LocalhostPorts": [
            3000,
            3001,
            4200,
            5000,
            5001,
            5173,
            7000,
            7001,
            8080,
            8081
        ],
        "EnforceStrictOriginsInProduction": true
        //"EnforceStrictOriginsInProduction": false
    },
    "ClientInfoSettings": {
        "IpHeaderKeys": [
            "X-Forwarded-For",
            "X-Real-IP"
        ]
    }
